        {
          "type": "host",
          "value": "learn-claude-source.com"
        }
      ],
      "destination": "https://www.learn-claude-source.com/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/",
      "permanent": false
    }
  ]
}
